rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Data Model
    // ===============================================================
    //
    // users / {userId}
    //   uid, name, email, isEnrolled, voiceprint[], role, createdAt,
    //   location?, passPhrase?, passPhraseLanguage?, passPhraseLanguageCode?,
    //   publicKey?, encryptedPrivateKey?
    //
    // file_history / {historyId}
    //   fileName, operation, userUid, userName, status, timestamp, location?
    //
    // system_logs / {logId}
    //   text, type, timestamp, userUid?, userName?, location?
    //
    // login_history / {userId} / sessions / {sessionId}
    //   userUid, userName, userEmail, timestamp, city?, region?,
    //   country?, timezone, lat?, lon?, displayName?
    //
    // user_security_events / {eventId}
    //   userId, action, summary, metadata?, userEmail?, displayName?,
    //   userAgent?, createdAt
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin = any user whose own /users/{uid} doc has role == 'admin'.
    // Bootstrap by editing a user doc directly in the Firestore console.
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId)
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.role in ['admin', 'user']
                    && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId)
                    && request.resource.data.uid == request.auth.uid
                    && (request.resource.data.role == resource.data.role || isAdmin());
      // Users can delete their OWN enrollment; admins can delete anyone's.
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /file_history/{historyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.userUid == request.auth.uid
                    && request.resource.data.operation in ['encrypt', 'decrypt']
                    && request.resource.data.status in ['success', 'failed'];
      allow update, delete: if isAdmin();
    }

    match /system_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.text is string
                    && request.resource.data.type in ['info', 'success', 'error', 'warning'];
      allow update, delete: if isAdmin();
    }

    match /login_history/{userId}/sessions/{sessionId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
                    && request.resource.data.userUid == request.auth.uid;
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /user_security_events/{eventId} {
      allow read: if isAuthenticated()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.action is string
                    && request.resource.data.summary is string
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Public connection test document (read-only)
    match /system/connection_test {
      allow read: if true;
    }
  }
}
